{
  "name": "glm-monitor",
  "displayName": "GLM Monitor",
  "description": "监控智谱 AI (BigModel) API Key 的使用量，在状态栏显示 Token 剩余百分比和重置时间",
  "version": "0.0.2",
  "publisher": "LaughSmiles",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/LaughSmiles/glm-key-monitor"
  },
  "license": "MIT",
  "homepage": "https://github.com/LaughSmiles/glm-key-monitor#readme",
  "bugs": {
    "url": "https://github.com/LaughSmiles/glm-key-monitor/issues"
  },
  "keywords": [
    "GLM",
    "智谱AI",
    "BigModel",
    "API Monitor",
    "Token Usage",
    "Speed Test"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "glmKeyMonitor.setKey",
        "title": "GLM: Set API Key"
      },
      {
        "command": "glmKeyMonitor.refresh",
        "title": "GLM: Refresh Usage"
      },
      {
        "command": "glmKeyMonitor.showUsageDetails",
        "title": "GLM: Show Usage Details"
      }
    ],
    "configuration": {
      "title": "GLM Key Monitor",
      "properties": {
        "glmKeyMonitor.refreshInterval": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "description": "自动刷新间隔（分钟）"
        },
        "glmKeyMonitor.speedTestModels": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "glm-4.7",
            "glm-5",
            "glm-5-turbo",
            "glm-5.1"
          ],
          "description": "测速模型列表（可在 Webview 中手动添加更多）"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "sharp": "^0.34.5",
    "typescript": "^5.3.0"
  }
}
